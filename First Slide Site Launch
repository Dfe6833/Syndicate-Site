<html lang="en"><head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Syndicate — Option A Light</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,700&amp;family=Lato:wght@300;400;700&amp;display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --gold:    #b8922a;
      --gold-lt: #d4ad55;
      --gold-dk: #8a6b1a;
      --cream:   #f8f4ee;
      --dark:    #1c1a16;
      --warm:    #f0ebe0;
    }

    body {
      background: #e8e4dc;
      font-family: 'Lato', sans-serif;
      padding: 40px 20px;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .scale-wrap {
      width: 100%;
      max-width: 1920px;
      transform-origin: top left;
    }

    .slide-a {
      width: 1920px;
      height: 800px;
      position: relative;
      overflow: hidden;
      display: flex;
      background: #f5f1ea;
    }

    /* subtle warm radial */
    .slide-a__bg {
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 70% 90% at 60% 50%, #f8f5ee 0%, #f0ece3 100%);
    }

    /* gold top/bottom rules */
    .slide-a__rule-top,
    .slide-a__rule-bottom {
      position: absolute;
      left: 80px; right: 80px;
      height: 1px;
      background: linear-gradient(to right, transparent, rgba(139,107,26,0.25) 20%, rgba(139,107,26,0.25) 80%, transparent);
      pointer-events: none;
    }
    .slide-a__rule-top { top: 55px; }
    .slide-a__rule-bottom { bottom: 55px; }

    /* LEFT text */
    .slide-a__text {
      position: relative;
      z-index: 2;
      width: 420px;
      flex-shrink: 0;
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 0 0 0 130px;
    }

    .slide-a__eyebrow {
      font-family: 'Lato', sans-serif;
      font-weight: 300;
      font-size: 12px;
      letter-spacing: 0.32em;
      text-transform: uppercase;
      color: var(--gold-dk);
      margin-bottom: 24px;
      opacity: 0;
      animation: fadeUp 0.6s ease forwards 0.2s;
    }

    .slide-a__headline {
      font-family: 'Playfair Display', serif;
      font-weight: 400;
      font-size: 58px;
      line-height: 1.1;
      color: var(--dark);
      margin-bottom: 24px;
      opacity: 0;
      animation: fadeUp 0.7s ease forwards 0.4s;
    }

    .slide-a__headline em {
      font-style: italic;
      color: var(--gold);
    }

    .slide-a__sub {
      font-family: 'Lato', sans-serif;
      font-weight: 300;
      font-size: 15px;
      line-height: 1.8;
      color: rgba(28,26,22,0.55);
      margin-bottom: 42px;
      opacity: 0;
      animation: fadeUp 0.7s ease forwards 0.6s;
    }

    .slide-a__cta {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      font-family: 'Lato', sans-serif;
      font-weight: 700;
      font-size: 11px;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--gold-dk);
      text-decoration: none;
      opacity: 0;
      animation: fadeUp 0.7s ease forwards 0.8s;
      transition: gap 0.2s;
    }
    .slide-a__cta::after { content: '→'; font-size: 15px; }
    .slide-a__cta:hover { gap: 18px; }

    /* RIGHT product columns */
    .slide-a__products {
      flex: 1;
      position: relative;
      z-index: 2;
      display: flex;
      align-items: stretch;
      padding: 70px 80px 70px 40px;
      gap: 1px;
    }

    .prod-col {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-end;
      border-left: 1px solid rgba(139,107,26,0.15);
      padding: 0 20px;
      position: relative;
      cursor: default;
      transition: border-color 0.25s, background 0.25s;
    }
    .prod-col:hover {
      border-left-color: rgba(139,107,26,0.4);
      background: rgba(184,146,42,0.04);
    }
    .prod-col::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 2px;
      background: var(--gold);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.3s ease;
    }
    .prod-col:hover::before { transform: scaleX(1); }

    .prod-col__img {
      width: 100%;
      max-height: 340px;
      object-fit: contain;
      object-position: bottom center;
      opacity: 0;
      animation: fadeUp 0.7s ease forwards;
    }

    .prod-col:nth-child(1) .prod-col__img { animation-delay: 0.5s; }
    .prod-col:nth-child(2) .prod-col__img { animation-delay: 0.65s; }
    .prod-col:nth-child(3) .prod-col__img { animation-delay: 0.8s; }
    .prod-col:nth-child(4) .prod-col__img { animation-delay: 0.95s; }
    .prod-col:nth-child(5) .prod-col__img { animation-delay: 1.1s; }

    .prod-col__meta {
      width: 100%;
      text-align: center;
      border-top: 1px solid rgba(139,107,26,0.2);
      padding: 16px 0 0;
      margin-top: 20px;
    }

    .prod-col__year {
      font-family: 'Playfair Display', serif;
      font-size: 11px;
      color: var(--gold-dk);
      letter-spacing: 0.1em;
      margin-bottom: 5px;
    }

    .prod-col__name {
      font-family: 'Playfair Display', serif;
      font-size: 14px;
      font-weight: 700;
      color: var(--dark);
      line-height: 1.3;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .label {
      font-family: 'Lato', sans-serif;
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: #888;
      margin-bottom: 14px;
    }
  </style>
</head>
<body>
  <p class="label">Option A — White background</p>
  <div class="scale-wrap" id="scaleWrap" style="transform: scale(0.738542); transform-origin: left top; height: 598.219px;">
    <div class="slide-a">
      <div class="slide-a__bg"></div>
      <div class="slide-a__rule-top"></div>
      <div class="slide-a__rule-bottom"></div>

      <div class="slide-a__text">
        <p class="slide-a__eyebrow">80 Years · Established 1946</p>
        <h2 class="slide-a__headline">The Products<br>Behind the<br><em>Legacy.</em></h2>
        <p class="slide-a__sub">Eight decades of changing<br>the way the world<br>does flowers.</p>
        <a href="#" class="slide-a__cta">Shop the Collection</a>
      </div>

      <div class="slide-a__products">
        <div class="prod-col">
          <img class="prod-col__img" src="data:image/jpeg;base64," alt="Aquapic">
          <div class="prod-col__meta">
            <div class="prod-col__year">1946</div>
            <div class="prod-col__name">Aquapic®</div>
          </div>
        </div>
        <div class="prod-col">
          <img class="prod-col__img" src="data:image/jpeg;base64," alt="Design Bowl">
          <div class="prod-col__meta">
            <div class="prod-col__year">1954</div>
            <div class="prod-col__name">Design Bowl</div>
          </div>
        </div>
        <div class="prod-col">
          <img class="prod-col__img" src="data:image/jpeg;base64," alt="Everlastin Basket">
          <div class="prod-col__meta">
            <div class="prod-col__year">1959</div>
            <div class="prod-col__name">Everlastin'® Basket</div>
          </div>
        </div>
        <div class="prod-col">
          <img class="prod-col__img" src="data:image/jpeg;base64," alt="Classic Rose Vase">
          <div class="prod-col__meta">
            <div class="prod-col__year">Since 1946</div>
            <div class="prod-col__name">Classic Rose Vase</div>
          </div>
        </div>
        <div class="prod-col">
          <img class="prod-col__img" src="data:image/jpeg;base64," alt="Foam Free Mechanic">
          <div class="prod-col__meta">
            <div class="prod-col__year">2017</div>
            <div class="prod-col__name">Foam Free Mechanic</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    function scale() {
      const wrap = document.getElementById('scaleWrap');
      const vw = window.innerWidth - 40;
      const s = Math.min(1, vw / 1920);
      wrap.style.transform = `scale(${s})`;
      wrap.style.transformOrigin = 'top left';
      wrap.style.height = (810 * s) + 'px';
    }
    scale();
    window.addEventListener('resize', scale);
  </script>

</body></html>
