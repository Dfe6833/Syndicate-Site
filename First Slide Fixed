          </div>
        </div>

        <div class="prod-col">
          <img class="prod-col__img" src="https://assets.syndicatesales.com/image/934860271560/image_bocgh51qbl64ddehk50l6j806v/-fnpg-S430x430" alt="Everlastin Basket">
          <div class="prod-col__meta">
