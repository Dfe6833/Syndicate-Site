        </div>

        <div class="prod-col">
          <img class="prod-col__img" src="https://assets.syndicatesales.com/image/934860271560/image_al5tgch3eh5qd72fi228bb2952/-fnpg-S430x430" alt="Foam Free Mechanic">
          <div class="prod-col__meta">
            <div class="prod-col__year">2017</div>
            <div class="prod-col__name">Foam Free Mechanic</div>
          </div>
        </div>

      </div>

    </div>
  </div>

</div>

<script>
(function(){
  var embed = document.getElementById('syndicateSlideEmbed');
  var wrap = document.getElementById('scaleWrap');

  function scale(){
    if(!embed || !wrap) return;
    var w = embed.clientWidth;
    var s = Math.min(1, w / 1920);
    wrap.style.transform = 'scale('+s+')';
    wrap.style.height = (800 * s) + 'px';
  }

  function animate(){
    embed.classList.add('play-animation');
  }

  scale();
  animate();

  window.addEventListener('resize', scale);
})();
</script>
