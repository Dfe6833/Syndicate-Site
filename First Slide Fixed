        <p class="slide-a__sub">Eight decades of changing<br>the way the world<br>does flowers.</p>
        <a href="#" class="slide-a__cta">Shop the Collection →</a>
      </div>

      <div class="slide-a__products">

        <div class="prod-col">
          <img class="prod-col__img" src="https://assets.syndicatesales.com/image/934860271560/image_t4ouncu6pt0n39hlum8tg9lm2n/-fnpg-S430x430" alt="Aquapic">
          <div class="prod-col__meta">
            <div class="prod-col__year">1946</div>
            <div class="prod-col__name">Aquapic</div>
          </div>
        </div>

        <div class="prod-col">
          <img class="prod-col__img" src="https://assets.syndicatesales.com/image/934860271560/image_v2qgrcfsfd7ln75bvqq14fvr5k/-fnpg-S430x430" alt="Design Bowl">
          <div class="prod-col__meta">
